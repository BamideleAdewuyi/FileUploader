<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
</head>
<body>
    <div class="homePageContainer">
        <% if (user) {%>
            <h1>Welcome back <%= user.username %></h1>
            <a href="/logOut">Log Out</a>
        <% } else { %>
            <a href="/signUp">Sign Up New User</a>
            <a href="/logIn">Log In</a>
        <% } %>
    </div>
</body>
</html>