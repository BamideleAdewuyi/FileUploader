<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Folder</title>
</head>
<body>
    <h1><%= folder.title %></h1>
    <div class="filesContainer">
        <% if (folder.file) { %>
            <ul>
                <% for (const file of folder.file) { %>
                    <li><a href=""><%= file.title %></a></li>
                <% } %>
            </ul>
        <% } else { %> 
            <h2>No files</h2>
        <% } %>
    </div>
    <a href="/">Back Home</a>
</body>
</html>